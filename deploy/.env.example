# Copy to .env and fill in. Never commit .env.

# Bearer token the Worker presents to the signer (must match the Worker's
# SIGNER_SHARED_SECRET).
SIGNER_SHARED_SECRET=

# Faucet seed as hex (32..=252 bytes; e.g. 64 hex chars for 32 bytes). Held
# only in scrubbed memory by the signer.
SIGNER_SEED=

# lightwalletd-protocol gRPC endpoint. Point this at your local zaino (backed
# by zebrad). From a container, reach a host process via host.docker.internal.
LIGHTWALLETD_URL=http://host.docker.internal:8137

# Path to the wallet SQLite database (persisted on a volume).
SIGNER_DB_PATH=/data/faucet-wallet.db

# Cloudflare Tunnel token for the cloudflared service (from the Cloudflare
# Zero Trust dashboard). The tunnel routes your public signer hostname to
# http://signer:8080.
CLOUDFLARED_TUNNEL_TOKEN=

# Heartbeat sidecar: seconds between faucet self-send transactions (liveness
# probe). Default 300 (every 5 minutes).
HEARTBEAT_INTERVAL=300

# Heartbeat self-send amount in zatoshis (1 TAZ = 100_000_000 zat). The amount
# returns to the faucet minus the ZIP-317 fee, so this is the per-run note size,
# not the cost. Default 1000.
HEARTBEAT_AMOUNT_ZAT=1000
